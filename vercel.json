{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    {
      "src": "/assets/.*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/pictures/.*",
      "headers": { "Cache-Control": "public, max-age=86400" }
    },
    {
      "src": "/.*\\.docx$",
      "headers": { "Cache-Control": "public, max-age=86400" }
    },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
